# Copilot service configuration

# Database (Required)
DATABASE_URL="postgresql://postgres:yourCopilotDataBasePassword@localhost:5433/copilot"

# Listening Port (Optional) - defaults to 5001 if not specified
# PORT=5001

# Authentication (Required)
INTERNAL_API_SECRET=your_internal_api_secret  # Use `openssl rand -hex 32` to generate; shared between TG ↔ copilot for service-to-service calls

# TradingGoose integration (Required)
OFFICIAL_TG_URL=http://localhost:3000

# Model Configuration (Optional)
# COPILOT_MODEL=gpt-4o-mini  # defaults to `gpt-4o-mini` if unset
COPILOT_MODEL=gpt-4o-mini

# AI Router (Optional)
AI_ROUTER_URL=https://openrouter.ai/api/v1
AI_ROUTER_API_KEY=some_valid_ai_provider_api_key
USE_OPENROUTER=true  # formats provider-scoped model names (e.g., `o3` → `openai/o3`) before calling the router

# Logging (Optional)
# COPILOT_LOG_LEVEL=debug
