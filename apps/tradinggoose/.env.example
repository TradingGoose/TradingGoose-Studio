# TradingGoose Studio app environment template
#
# Scope: apps/tradinggoose only.
# Copy to apps/tradinggoose/.env for local development.
#
# Notes:
# - Boolean-like flags should use true/false.
# - Lists use comma-separated values with no surrounding spaces unless noted.
# - Storage provider auto-detection order is: Azure Blob > S3 > local disk.
# - For local development, the minimum required variables are the ones in the first section.

###############################################################################
# Minimum local development
###############################################################################

# Required: PostgreSQL connection string used by the Next app and socket server.
# The default local Docker setup in this repo uses postgres/postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradinggoose"

# Required: public browser URL for this app.
# This should match the URL you actually open in your browser.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required: Better Auth base URL.
# In local development this should usually match NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL="http://localhost:3000"

# Required: Better Auth signing secret.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-64-hex-characters"

# Required: 32-byte encryption key for stored secrets.
# Best format is 64 hex chars from: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-64-hex-characters"

# Optional: dedicated encryption key for stored API credentials.
# If unset, API keys fall back to the default encryption behavior.
# Generate with: openssl rand -hex 32
# API_ENCRYPTION_KEY="replace-with-64-hex-characters"

# Required: internal JWT / server-to-server secret.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET="replace-with-64-hex-characters"
