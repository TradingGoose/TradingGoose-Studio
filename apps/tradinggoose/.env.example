# TradingGoose Studio app environment template
#
# Scope: apps/tradinggoose only.
# Copy to apps/tradinggoose/.env for local development.
#
# Notes:
# - Boolean-like flags should use true/false.
# - Lists use comma-separated values with no surrounding spaces unless noted.
# - Storage provider auto-detection order is: Azure Blob > S3 > local disk.
# - For local development, the minimum required variables are the ones in the first section.

###############################################################################
# Minimum local development
###############################################################################

# Required: PostgreSQL connection string used by the Next app and socket server.
DATABASE_URL="postgresql://postgres:password@localhost:5432/tradinggoose"

# Required: public browser URL for this app.
# This should match the URL you actually open in your browser.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required: Better Auth base URL.
# In local development this should usually match NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL="http://localhost:3000"

# Required: Better Auth signing secret.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-64-hex-characters"

# Required: 32-byte encryption key for stored secrets.
# Best format is 64 hex chars from: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-64-hex-characters"

# Optional: dedicated encryption key for stored API credentials.
# If unset, API keys fall back to the default encryption behavior.
# Generate with: openssl rand -hex 32
# API_ENCRYPTION_KEY="replace-with-64-hex-characters"

# Required: internal JWT / server-to-server secret.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET="replace-with-64-hex-characters"

# Recommended for local realtime features.
# The app falls back to http://localhost:3002 if unset.
NEXT_PUBLIC_SOCKET_URL="http://localhost:3002"

# Optional server-side socket base URL for app-to-socket calls.
# The app falls back to http://localhost:3002 if unset.
SOCKET_SERVER_URL="http://localhost:3002"

# Optional: Next.js / Bun environment.
NODE_ENV="development"

# Optional compatibility alias used by one credential resolver path.
# If unset, that code path falls back to http://localhost:3000.
# NEXTAUTH_URL="http://localhost:3000"

###############################################################################
# App runtime and deployment behavior
###############################################################################

# Optional: main app port for production-style launches.
# `bun run dev` already binds Next.js to port 3000.
# PORT=3000

# Optional: socket server port.
# socket-server/index.ts uses PORT first, then SOCKET_PORT, then 3002.
# SOCKET_PORT=3002

# Optional: additional CORS origins for the socket server.
# Comma-separated, for example: http://localhost:3000,http://localhost:3001
# ALLOWED_ORIGINS=

# Optional: disable Next.js telemetry when set to 1.
# NEXT_TELEMETRY_DISABLED=1

# Optional: Docker build helper used by next.config.ts to relax build checks.
# DOCKER_BUILD=false

# Framework-managed by Next.js. Do not usually set manually.
# NEXT_RUNTIME=nodejs

###############################################################################
# Authentication, registration, and login restrictions
###############################################################################

# Optional: disable all new registrations.
# DISABLE_REGISTRATION=false

# Optional: allow sign-in only for specific email addresses.
# Comma-separated, lowercase recommended.
# ALLOWED_LOGIN_EMAILS=alice@example.com,bob@example.com

# Optional: allow sign-in only for specific email domains.
# Comma-separated, lowercase recommended.
# ALLOWED_LOGIN_DOMAINS=example.com,company.com

# Optional: require email verification for email/password auth flows.
# EMAIL_VERIFICATION_ENABLED=false

# Optional: hide email/password signup and login UI when false.
# Default behavior if unset is enabled.
# NEXT_PUBLIC_EMAIL_PASSWORD_SIGNUP_ENABLED=true

###############################################################################
# Billing and subscription configuration
###############################################################################

# Optional: enable billing-related UI and enforcement.
# Turning this on is only useful when Stripe keys and price IDs are also configured.
# NEXT_PUBLIC_BILLING_ENABLED=false

# Optional: Stripe secret key used for billing, subscriptions, and webhooks.
# STRIPE_SECRET_KEY=

# Optional: Stripe webhook signing secret.
# Required if you enable Stripe webhooks.
# STRIPE_WEBHOOK_SECRET=

# Optional: Stripe price IDs for each plan.
# STRIPE_FREE_PRICE_ID=
# STRIPE_PRO_PRICE_ID=
# STRIPE_TEAM_PRICE_ID=
# STRIPE_ENTERPRISE_PRICE_ID=

# Optional: per-plan monthly credit/cost limits.
# Code defaults when unset: free=10, pro=20, team=40, enterprise=200
# FREE_TIER_COST_LIMIT=10
# PRO_TIER_COST_LIMIT=20
# TEAM_TIER_COST_LIMIT=40
# ENTERPRISE_TIER_COST_LIMIT=200

# Optional: per-plan storage limits in GB.
# Code defaults when unset: free=5, pro=50, team=500, enterprise=500
# FREE_STORAGE_LIMIT_GB=5
# PRO_STORAGE_LIMIT_GB=50
# TEAM_STORAGE_LIMIT_GB=500
# ENTERPRISE_STORAGE_LIMIT_GB=500

# Optional: create incremental overage charges once accrued overage reaches this amount.
# Default when unset is 50.
# OVERAGE_THRESHOLD_DOLLARS=50

###############################################################################
# Email, notifications, and SMS
###############################################################################

# Optional: primary transactional email provider.
# If unset, emails are logged instead of sent.
# RESEND_API_KEY=

# Optional: fallback / alternative email provider.
# Used via Azure Communication Services email client.
# AZURE_ACS_CONNECTION_STRING=

# Optional: explicit From header for outgoing mail.
# If unset, the app builds noreply@<EMAIL_DOMAIN or app domain>.
# FROM_EMAIL_ADDRESS="TradingGoose <noreply@example.com>"

# Optional: email domain used when FROM_EMAIL_ADDRESS is unset.
# EMAIL_DOMAIN="example.com"

# Optional: Twilio SMS credentials for SMS tools / triggers.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER="+15555550123"

###############################################################################
# Copilot service, model routing, and AI provider credentials
###############################################################################

# Optional: default server-side provider/model override used by some copilot routes.
# Provider examples: anthropic, openai, azure-openai, google, groq, mistral, ollama
# COPILOT_PROVIDER=anthropic
# COPILOT_MODEL=claude-3-7-sonnet-latest

# Optional: remote copilot service URL and auth.
# Default base URL when unset is https://copilot.tradinggoose.ai
# COPILOT_API_URL="https://copilot.tradinggoose.ai"
# COPILOT_API_KEY=

# Optional: training/indexer service used by copilot training endpoints.
# AGENT_INDEXER_URL=
# AGENT_INDEXER_API_KEY=

# Optional: expose training UI/features in the browser.
# NEXT_PUBLIC_COPILOT_TRAINING_ENABLED=false

# Optional advanced chat override values from lib/copilot/config.ts.
# Valid provider values:
# openai, azure-openai, anthropic, google, deepseek, xai, cerebras, mistral, groq, ollama
# Defaults when unset:
# - provider: anthropic
# - model: claude-3-7-sonnet-latest
# - temperature: 0.1
# - max tokens: 8192
# COPILOT_CHAT_PROVIDER=anthropic
# COPILOT_CHAT_MODEL=claude-3-7-sonnet-latest
# COPILOT_CHAT_TEMPERATURE=0.1
# COPILOT_CHAT_MAX_TOKENS=8192

# Optional advanced RAG/search override values from lib/copilot/config.ts.
# Defaults when unset:
# - provider: anthropic
# - model: claude-3-7-sonnet-latest
# - temperature: 0.1
# - max tokens: 2000
# - max sources: 10
# - similarity threshold: 0.3
# COPILOT_RAG_PROVIDER=anthropic
# COPILOT_RAG_MODEL=claude-3-7-sonnet-latest
# COPILOT_RAG_TEMPERATURE=0.1
# COPILOT_RAG_MAX_TOKENS=2000
# COPILOT_RAG_MAX_SOURCES=10
# COPILOT_RAG_SIMILARITY_THRESHOLD=0.3

# Optional additional copilot behavior overrides.
# Defaults when unset:
# - streaming enabled: true
# - max conversation history: 10
# - title generation model: claude-3-haiku-20240307
# - tool result char cap: 20000
# COPILOT_STREAMING_ENABLED=true
# COPILOT_MAX_CONVERSATION_HISTORY=10
# COPILOT_TITLE_GENERATION_MODEL=claude-3-haiku-20240307
# COPILOT_TOOL_RESULT_CHAR_CAP=20000

# Core AI provider keys.
# OPENAI_API_KEY is used for embeddings unless Azure OpenAI config is fully provided.
# Additional *_1/2/3 keys are used for load balancing in some provider utilities.
# OPENAI_API_KEY=
# OPENAI_API_KEY_1=
# OPENAI_API_KEY_2=
# OPENAI_API_KEY_3=
# ANTHROPIC_API_KEY_1=
# ANTHROPIC_API_KEY_2=
# ANTHROPIC_API_KEY_3=
# MISTRAL_API_KEY=

# Optional: local Ollama endpoint.
# Default when unset is http://localhost:11434
# OLLAMA_URL="http://localhost:11434"

# Optional: enable DeepSeek models in the UI.
# Default when unset is false.
# DEEPSEEK_MODELS_ENABLED=false

# Optional: Azure OpenAI shared config.
# Embeddings require either:
# - OPENAI_API_KEY
# - or AZURE_OPENAI_API_KEY + AZURE_OPENAI_ENDPOINT
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-07-01-preview
# AZURE_OPENAI_API_KEY=

# Optional: override model names used in specific features.
# KB_OPENAI_MODEL_NAME is used for knowledge-base embeddings/search.
# WAND_OPENAI_MODEL_NAME is used by the wand copilot route.
# KB_OPENAI_MODEL_NAME=text-embedding-3-small
# WAND_OPENAI_MODEL_NAME=gpt-4o-mini

# Optional: PDF OCR providers.
# Azure Mistral OCR is used when all three Azure OCR vars are set.
# Otherwise PDF OCR falls back to MISTRAL_API_KEY when available.
# OCR_AZURE_ENDPOINT=
# OCR_AZURE_MODEL_NAME=
# OCR_AZURE_API_KEY=

# Optional: extra AI-adjacent integrations.
# ELEVENLABS_API_KEY=
# SERPER_API_KEY=
# EXA_API_KEY=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# Optional: GitHub API token used by app routes/tools.
# GITHUB_TOKEN=

# Optional: Trello REST API key used by Trello tools.
# TRELLO_API_KEY=

###############################################################################
# Market API and quote-provider credentials
###############################################################################

# Optional: shared TradingGoose Market service config.
# Default URL when unset is https://market.tradinggoose.ai
# MARKET_API_URL="https://market.tradinggoose.ai"
# MARKET_API_KEY=

# Optional: provider-specific fallback credentials used when user-supplied auth is absent.
# Alpaca stock data requires both API key ID and secret if per-request auth is not provided.
# ALPACA_API_KEY_ID=
# ALPACA_API_SECRET_KEY=

# Finnhub series requests require a key if that provider is used.
# FINNHUB_API_KEY=

# Alpha Vantage series requests require a key if that provider is used.
# ALPHAVANTAGE_API_KEY=

###############################################################################
# Remote code execution, async jobs, and concurrency controls
###############################################################################

# Optional: enable E2B remote execution.
# E2B_API_KEY becomes required if E2B_ENABLED=true.
# E2B_ENABLED=false
# E2B_API_KEY=

# Optional: prebuilt E2B template for indicator/function execution.
# Created by scripts/create-e2b-pinets-template.ts
# E2B_INDICATOR_TEMPLATE_ID=

# Optional: E2B warm sandbox tuning.
# Defaults when unset:
# - keep warm cap: 3600000 ms
# - requested keep warm target: 300000 ms
# E2B_KEEP_WARM_CAP_MS=3600000
# E2B_KEEP_WARM_TARGET_MS=300000

# Optional: hard cap on process-local warm E2B sandboxes before local fallback.
# E2B_MAX_CONCURRENT_SANDBOX=

# Optional: local VM concurrency limits.
# Defaults when unset:
# - total concurrent local executions: 200
# - per-owner limit: unlimited
# LOCAL_VM_MAX_CONCURRENT_EXECUTIONS=200
# LOCAL_VM_MAX_ACTIVE_PER_OWNER=

# Optional: Trigger.dev async background jobs.
# Trigger-backed knowledge processing is considered available when TRIGGER_SECRET_KEY is set.
# TRIGGER_PROJECT_ID=
# TRIGGER_SECRET_KEY=
# TRIGGER_DEV_ENABLED=true

# Optional: browser UI flag for async execution / Trigger.dev features.
# Keep this aligned with TRIGGER_DEV_ENABLED if you want the UI to match backend capability.
# NEXT_PUBLIC_TRIGGER_DEV_ENABLED=false

# Optional: internal job retention metadata used by some async flows.
# Default when unset is 1.
# JOB_RETENTION_DAYS=1

# Optional: CRON secret used by protected scheduled endpoints such as log cleanup.
# Requests must send: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET="replace-with-a-long-random-secret"

# Optional: Redis enables shared caching and distributed concurrency guards.
# If unset, the app falls back to in-memory behavior where supported.
# REDIS_URL="redis://localhost:6379"

###############################################################################
# File storage and uploads
###############################################################################

# Configure exactly one cloud storage family if desired.
# Auto-detection priority is Blob first, then S3, then local disk.

# Optional: S3 / compatible object storage.
# Minimum S3 config for cloud uploads is S3_BUCKET_NAME + AWS_REGION.
# Providing AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY enables explicit credential auth.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=tradinggoose-files

# Optional S3 bucket overrides for specialized file categories.
# S3_LOGS_BUCKET_NAME=
# S3_KB_BUCKET_NAME=
# S3_EXECUTION_FILES_BUCKET_NAME=sim-execution-files
# S3_CHAT_BUCKET_NAME=
# S3_COPILOT_BUCKET_NAME=
# S3_PROFILE_PICTURES_BUCKET_NAME=

# Optional: Azure Blob storage.
# Minimum Blob config for cloud uploads is:
# - AZURE_STORAGE_CONTAINER_NAME
# - and either AZURE_CONNECTION_STRING
#   or AZURE_ACCOUNT_NAME + AZURE_ACCOUNT_KEY
# AZURE_ACCOUNT_NAME=
# AZURE_ACCOUNT_KEY=
# AZURE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_NAME=tradinggoose-files

# Optional Azure container overrides for specialized file categories.
# AZURE_STORAGE_KB_CONTAINER_NAME=
# AZURE_STORAGE_EXECUTION_FILES_CONTAINER_NAME=sim-execution-files
# AZURE_STORAGE_CHAT_CONTAINER_NAME=
# AZURE_STORAGE_COPILOT_CONTAINER_NAME=
# AZURE_STORAGE_PROFILE_PICTURES_CONTAINER_NAME=

###############################################################################
# Logs, telemetry, and rate limiting
###############################################################################

# Optional: custom OTLP endpoint for server telemetry.
# Default when unset is https://telemetry.simstudio.ai/v1/traces
# TELEMETRY_ENDPOINT="https://telemetry.simstudio.ai/v1/traces"

# Optional: cost multiplier applied in production by lib/environment.ts.
# Default when unset is 1.
# COST_MULTIPLIER=1

# Optional: console log level override.
# Valid values: DEBUG, INFO, WARN, ERROR
# Default when unset:
# - development: DEBUG
# - production: ERROR
# - test: ERROR
# LOG_LEVEL=DEBUG

# Optional: free-plan execution log retention window in days.
# The cleanup route defaults to 7 when unset.
# FREE_PLAN_LOG_RETENTION_DAYS=7

# Optional: API execution rate limits.
# Defaults when unset are shown below.
# RATE_LIMIT_WINDOW_MS=60000
# MANUAL_EXECUTION_LIMIT=999999
# RATE_LIMIT_FREE_SYNC=10
# RATE_LIMIT_FREE_ASYNC=50
# RATE_LIMIT_PRO_SYNC=25
# RATE_LIMIT_PRO_ASYNC=200
# RATE_LIMIT_TEAM_SYNC=75
# RATE_LIMIT_TEAM_ASYNC=500
# RATE_LIMIT_ENTERPRISE_SYNC=150
# RATE_LIMIT_ENTERPRISE_ASYNC=1000

# Optional: knowledge-base ingestion / retry tuning.
# Defaults when unset:
# - max duration: 600 seconds
# - max attempts: 3
# - retry factor: 2
# - min timeout: 1000 ms
# - max timeout: 10000 ms
# - concurrency limit: 20
# - batch size: 20
# - delay between batches: 100 ms
# - delay between documents: 50 ms
# KB_CONFIG_MAX_DURATION=600
# KB_CONFIG_MAX_ATTEMPTS=3
# KB_CONFIG_RETRY_FACTOR=2
# KB_CONFIG_MIN_TIMEOUT=1000
# KB_CONFIG_MAX_TIMEOUT=10000
# KB_CONFIG_CONCURRENCY_LIMIT=20
# KB_CONFIG_BATCH_SIZE=20
# KB_CONFIG_DELAY_BETWEEN_BATCHES=100
# KB_CONFIG_DELAY_BETWEEN_DOCUMENTS=50

###############################################################################
# Public branding, analytics, and client integrations
###############################################################################

# Optional: PostHog browser analytics.
# NEXT_PUBLIC_POSTHOG_ENABLED=false
# NEXT_PUBLIC_POSTHOG_KEY=

# Optional: white-label branding.
# NEXT_PUBLIC_BRAND_NAME="TradingGoose"
# NEXT_PUBLIC_BRAND_LOGO_URL="https://example.com/logo.svg"
# NEXT_PUBLIC_BRAND_FAVICON_URL="https://example.com/favicon.ico"
# NEXT_PUBLIC_CUSTOM_CSS_URL="https://example.com/theme.css"
# NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"
# NEXT_PUBLIC_DOCUMENTATION_URL="https://docs.example.com"
# NEXT_PUBLIC_TERMS_URL="https://example.com/terms"
# NEXT_PUBLIC_PRIVACY_URL="https://example.com/privacy"

# Optional: theme color overrides.
# Must be 6- or 8-digit hex values, for example #0F172A or #0F172ACC
# NEXT_PUBLIC_BRAND_PRIMARY_COLOR="#0B5FFF"
# NEXT_PUBLIC_BRAND_PRIMARY_HOVER_COLOR="#084EDB"
# NEXT_PUBLIC_BRAND_ACCENT_COLOR="#14B8A6"
# NEXT_PUBLIC_BRAND_ACCENT_HOVER_COLOR="#0D9488"
# NEXT_PUBLIC_BRAND_BACKGROUND_COLOR="#F8FAFC"

# Optional: client-side Google config used by Drive picker / browser integrations.
# These are separate from the server-side OAuth client credentials below.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_API_KEY=
# NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=

###############################################################################
# OAuth / app integration credentials
###############################################################################

# Only configure the providers you actually enable.
# These are server-side credentials used by Better Auth and integration flows.

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Optional separate GitHub app credentials for repo-scoped access flows.
# GITHUB_REPO_CLIENT_ID=
# GITHUB_REPO_CLIENT_SECRET=

# X_CLIENT_ID=
# X_CLIENT_SECRET=

# CONFLUENCE_CLIENT_ID=
# CONFLUENCE_CLIENT_SECRET=

# JIRA_CLIENT_ID=
# JIRA_CLIENT_SECRET=

# AIRTABLE_CLIENT_ID=
# AIRTABLE_CLIENT_SECRET=

# SUPABASE_CLIENT_ID=
# SUPABASE_CLIENT_SECRET=

# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=

# WEALTHBOX_CLIENT_ID=
# WEALTHBOX_CLIENT_SECRET=

# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=

# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# TRADIER_CLIENT_ID=
# TRADIER_CLIENT_SECRET=

# ROBINHOOD_CLIENT_ID=
# ROBINHOOD_CLIENT_SECRET=

# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# WEBFLOW_CLIENT_ID=
# WEBFLOW_CLIENT_SECRET=

# Optional Alpaca OAuth credentials.
# These are different from ALPACA_API_KEY_ID / ALPACA_API_SECRET_KEY above.
# ALPACA_CLIENT_ID=
# ALPACA_CLIENT_SECRET=

###############################################################################
# SSO configuration
###############################################################################

# Optional: server-side SSO enablement and browser UI gate.
# If you enable SSO for the app, keep these aligned.
# SSO_ENABLED=false
# NEXT_PUBLIC_SSO_ENABLED=false

# Required when SSO is enabled:
# - SSO_PROVIDER_TYPE: oidc or saml
# - SSO_PROVIDER_ID
# - SSO_ISSUER
# - SSO_DOMAIN
# - SSO_USER_EMAIL
# SSO_PROVIDER_TYPE=oidc
# SSO_PROVIDER_ID=company-sso
# SSO_ISSUER="https://idp.example.com"
# SSO_DOMAIN=example.com
# SSO_USER_EMAIL=admin@example.com

# Optional: target organization for script-based SSO registration.
# SSO_ORGANIZATION_ID=

# Optional claim/attribute mappings.
# Defaults when unset:
# - id: sub for OIDC, nameidentifier for SAML
# - email: email for OIDC, emailaddress for SAML
# - name: name
# - image: picture for OIDC
# SSO_MAPPING_ID=
# SSO_MAPPING_EMAIL=
# SSO_MAPPING_NAME=
# SSO_MAPPING_IMAGE=

# OIDC-specific settings.
# Required for OIDC:
# - SSO_OIDC_CLIENT_ID
# - SSO_OIDC_CLIENT_SECRET
# Optional defaults:
# - scopes: openid,profile,email
# - pkce: true
# - discovery endpoint: <issuer>/.well-known/openid-configuration
# SSO_OIDC_CLIENT_ID=
# SSO_OIDC_CLIENT_SECRET=
# SSO_OIDC_SCOPES=openid,profile,email
# SSO_OIDC_PKCE=true
# SSO_OIDC_AUTHORIZATION_ENDPOINT=
# SSO_OIDC_TOKEN_ENDPOINT=
# SSO_OIDC_USERINFO_ENDPOINT=
# SSO_OIDC_JWKS_ENDPOINT=
# SSO_OIDC_DISCOVERY_ENDPOINT=

# SAML-specific settings.
# Required for SAML:
# - SSO_SAML_ENTRY_POINT
# - SSO_SAML_CERT
# Optional defaults:
# - callback URL: <issuer>/callback
# - audience: issuer URL
# - want assertions signed: false
# - SP metadata: auto-generated when omitted
# SSO_SAML_ENTRY_POINT=
# SSO_SAML_CERT=
# SSO_SAML_CALLBACK_URL=
# SSO_SAML_SP_METADATA=
# SSO_SAML_IDP_METADATA=
# SSO_SAML_AUDIENCE=
# SSO_SAML_WANT_ASSERTIONS_SIGNED=false
# SSO_SAML_SIGNATURE_ALGORITHM=
# SSO_SAML_DIGEST_ALGORITHM=
# SSO_SAML_IDENTIFIER_FORMAT=

###############################################################################
# Local preview / email tooling / framework-managed edge cases
###############################################################################

# Optional: used by React Email preview fallback logic.
# EMAILS_PREVIEW_BASE_URL="http://localhost:3000"

# Optional: special-case preview flag checked by lib/urls/utils.ts.
# Usually not needed in normal local development.
# NEXT_PUBLIC_IS_PREVIEW_DEVELOPMENT=false

# Usually set by React Email tooling rather than manually.
# EMAILS_DIR_ABSOLUTE_PATH=
# PREVIEW_SERVER_LOCATION=
