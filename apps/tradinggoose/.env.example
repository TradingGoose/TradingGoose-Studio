# TradingGoose Studio app environment template
#
# Scope: apps/tradinggoose only.
# Copy to apps/tradinggoose/.env for local development.
#
# Ownership rules:
# - Keep boot-time, infra, public, and Better Auth social-login config in this file.
# - Configure runtime provider credentials in Admin Services instead:
#   OpenAI, Anthropic, Azure OpenAI, Serper, Exa, Resend, Stripe, Browserbase,
#   Copilot API, Market API, Agent Indexer, E2B, Mistral OCR, GitHub token, etc.
# - Configure system-managed integration OAuth apps in Admin Integrations instead:
#   google-drive, google-email, github-repo, microsoft, slack, reddit, etc.
# - Platform-managed vars like NODE_ENV, NEXT_RUNTIME, and VERCEL are omitted on purpose.
# - Internal React Email preview vars like EMAILS_DIR_ABSOLUTE_PATH and
#   PREVIEW_SERVER_LOCATION are also omitted on purpose.
#
# Notes:
# - Boolean-like flags should use true/false unless noted otherwise.
# - Lists use comma-separated values with no surrounding spaces.
# - Storage provider auto-detection order is: Azure Blob > S3 > local disk.

###############################################################################
# Minimum local development
###############################################################################

# Required: PostgreSQL connection string used by the Next app, socket server,
# and local Drizzle commands.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradinggoose"

# Required: public browser URL for the Studio app.
# This should match the URL you actually open in your browser.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required: Better Auth base URL.
# In local development this should usually match NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL="http://localhost:3000"

# Required: Better Auth signing secret.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-64-hex-characters"

# Required: default secret encryption key for stored secrets.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-64-hex-characters"

# Recommended: dedicated encryption key for stored API credentials.
# Generate with: openssl rand -hex 32
API_ENCRYPTION_KEY="replace-with-64-hex-characters"

# Required: internal server-to-server auth secret used by app routes, sockets,
# cron endpoints, and other internal calls.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET="replace-with-64-hex-characters"

# Recommended: Redis for cache, locks, idempotency, and rate limiting.
# Local Docker default in this repo typically exposes Redis on 6379.
REDIS_URL="redis://localhost:6379"

# Recommended for `bun run dev:full`: Socket server origin and public client URL.
SOCKET_SERVER_URL="http://localhost:3002"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3002"

# Required by the browser Yjs/socket bootstrap path.
NEXT_PUBLIC_SOCKET_PORT="3002"

# Socket server port for `bun run dev:sockets`.
SOCKET_PORT="3002"

###############################################################################
# Authentication and login policy
###############################################################################

# Optional: restrict who can log in by exact email addresses.
# Example: "alice@example.com,bob@example.com"
# ALLOWED_LOGIN_EMAILS=""

# Optional: restrict who can log in by email domain.
# Example: "example.com,example.org"
# ALLOWED_LOGIN_DOMAINS=""

# Optional: require email verification on sign-up / sign-in.
EMAIL_VERIFICATION_ENABLED="false"

# Optional: enable SSO endpoints and UI.
SSO_ENABLED="false"
NEXT_PUBLIC_SSO_ENABLED="false"

###############################################################################
# Better Auth social login (env-only, not DB-backed)
###############################################################################

# Optional: GitHub social sign-in for Better Auth.
# These are only for user sign-in and must stay env-backed.
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Optional: Google social sign-in for Better Auth.
# These are only for user sign-in and must stay env-backed.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

###############################################################################
# Client-side Google integrations
###############################################################################

# Optional: browser-side Google APIs such as Drive picker.
# These are public client values, not system OAuth integration secrets.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# NEXT_PUBLIC_GOOGLE_API_KEY=""
# NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=""

###############################################################################
# Trigger.dev, cron, and background jobs
###############################################################################

# Optional: Trigger.dev project config.
# Async execution itself is controlled from system settings.
# TRIGGER_PROJECT_ID=""
# TRIGGER_SECRET_KEY=""

# Optional: secret expected by cron/internal scheduled requests.
# Generate with: openssl rand -hex 32
# CRON_SECRET="replace-with-64-hex-characters"

# Optional: retention window for job logs / metadata.
JOB_RETENTION_DAYS="1"

###############################################################################
# Runtime behavior and observability
###############################################################################

# Optional: custom OTLP HTTP trace endpoint.
# TELEMETRY_ENDPOINT="https://telemetry.tradinggoose.ai/v1/traces"

# Optional: DEBUG, INFO, WARN, or ERROR.
# Defaults to DEBUG in development and ERROR in production when unset.
# LOG_LEVEL="INFO"

# Optional: disable Next.js telemetry when set to "1".
NEXT_TELEMETRY_DISABLED="1"

# Optional: increase rate-limit window for the in-process queue layer.
RATE_LIMIT_WINDOW_MS="60000"

# Optional: effectively unlimited by default; lower if you want a local cap.
MANUAL_EXECUTION_LIMIT="999999"

###############################################################################
# Copilot model defaults and tuning
###############################################################################

# Optional: override the default model/provider selection used by Studio when it
# calls the Copilot service.
# Valid providers: openai, azure-openai, anthropic, google, deepseek, xai,
# cerebras, mistral, groq, ollama
# COPILOT_CHAT_PROVIDER="anthropic"
# COPILOT_CHAT_MODEL="claude-3-7-sonnet-latest"
# COPILOT_CHAT_TEMPERATURE="0.1"
# COPILOT_CHAT_MAX_TOKENS="8192"

# Optional: documentation / RAG response model config.
# COPILOT_RAG_PROVIDER="anthropic"
# COPILOT_RAG_MODEL="claude-3-7-sonnet-latest"
# COPILOT_RAG_TEMPERATURE="0.1"
# COPILOT_RAG_MAX_TOKENS="2000"
# COPILOT_RAG_MAX_SOURCES="10"
# COPILOT_RAG_SIMILARITY_THRESHOLD="0.3"

# Optional: Copilot session behavior.
COPILOT_STREAMING_ENABLED="true"
COPILOT_MAX_CONVERSATION_HISTORY="10"
# COPILOT_TITLE_GENERATION_MODEL="claude-3-haiku-20240307"

# Optional: truncate oversized tool responses returned to the chat UI.
COPILOT_TOOL_RESULT_CHAR_CAP="20000"

###############################################################################
# Storage providers
###############################################################################

# Optional: AWS S3 storage.
# Set the base bucket plus any specialized buckets you want to separate.
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET_NAME=""
# S3_LOGS_BUCKET_NAME=""
# S3_KB_BUCKET_NAME=""
# S3_EXECUTION_FILES_BUCKET_NAME=""
# S3_CHAT_BUCKET_NAME=""
# S3_COPILOT_BUCKET_NAME=""
# S3_PROFILE_PICTURES_BUCKET_NAME=""

# Optional: Azure Blob storage.
# Use either AZURE_CONNECTION_STRING or AZURE_ACCOUNT_NAME + AZURE_ACCOUNT_KEY.
# AZURE_ACCOUNT_NAME=""
# AZURE_ACCOUNT_KEY=""
# AZURE_CONNECTION_STRING=""
# AZURE_STORAGE_CONTAINER_NAME=""
# AZURE_STORAGE_KB_CONTAINER_NAME=""
# AZURE_STORAGE_EXECUTION_FILES_CONTAINER_NAME=""
# AZURE_STORAGE_CHAT_CONTAINER_NAME=""
# AZURE_STORAGE_COPILOT_CONTAINER_NAME=""
# AZURE_STORAGE_PROFILE_PICTURES_CONTAINER_NAME=""

###############################################################################
# SMS / telephony
###############################################################################

# Optional: Twilio SMS sending.
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

###############################################################################
# Knowledge-base processing limits
###############################################################################

# Optional: retry and batching controls for knowledge processing.
KB_CONFIG_MAX_DURATION="600"
KB_CONFIG_MAX_ATTEMPTS="3"
KB_CONFIG_RETRY_FACTOR="2"
KB_CONFIG_MIN_TIMEOUT="1000"
KB_CONFIG_MAX_TIMEOUT="10000"
KB_CONFIG_CONCURRENCY_LIMIT="20"
KB_CONFIG_BATCH_SIZE="20"
KB_CONFIG_DELAY_BETWEEN_BATCHES="100"
KB_CONFIG_DELAY_BETWEEN_DOCUMENTS="50"

###############################################################################
# Public branding and product links
###############################################################################

# Optional: white-label / branding overrides.
# NEXT_PUBLIC_BRAND_NAME="TradingGoose"
# NEXT_PUBLIC_BRAND_LOGO_URL="https://example.com/logo.svg"
# NEXT_PUBLIC_BRAND_FAVICON_URL="https://example.com/favicon.ico"
# NEXT_PUBLIC_CUSTOM_CSS_URL="https://example.com/brand.css"
# NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"
# NEXT_PUBLIC_DOCUMENTATION_URL="https://docs.example.com"
# NEXT_PUBLIC_TERMS_URL="https://example.com/terms"
# NEXT_PUBLIC_PRIVACY_URL="https://example.com/privacy"

# Optional: theme colors in #RRGGBB or #RRGGBBAA format.
# NEXT_PUBLIC_BRAND_PRIMARY_COLOR="#0ea5e9"
# NEXT_PUBLIC_BRAND_PRIMARY_HOVER_COLOR="#0284c7"
# NEXT_PUBLIC_BRAND_ACCENT_COLOR="#22c55e"
# NEXT_PUBLIC_BRAND_ACCENT_HOVER_COLOR="#16a34a"
# NEXT_PUBLIC_BRAND_BACKGROUND_COLOR="#ffffff"

# Optional: PostHog frontend analytics.
# NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_DISABLED="1"

###############################################################################
# Market/provider fallback keys used directly by some local integrations
###############################################################################

# Optional: these envs are only used as direct fallback credentials by certain
# market integrations when no explicit auth is supplied in the request/runtime.
# They are not part of Admin Services.
# ALPACA_API_KEY_ID=""
# ALPACA_API_SECRET_KEY=""
# FINNHUB_API_KEY=""
# ALPHAVANTAGE_API_KEY=""

###############################################################################
# Blog content source
###############################################################################

# Optional: fetch landing-page blog content from a public GitHub repo instead of
# the local app/(landing)/blog/content directory. The GitHub token, if needed for
# higher API limits, is configured in Admin Services rather than here.
# BLOG_GITHUB_REPO="TradingGoose/blog"
BLOG_GITHUB_BRANCH="main"

###############################################################################
# Email preview / local tooling
###############################################################################

# Optional: only used by React Email preview and similar local tooling when
# NEXT_PUBLIC_APP_URL is not available in that process.
# EMAILS_PREVIEW_BASE_URL="http://localhost:3000"

###############################################################################
# Deployment and local infrastructure helpers
###############################################################################

# Optional: additional allowed origins for Socket.IO CORS.
# Example: "https://app.example.com,https://studio.example.com"
# ALLOWED_ORIGINS=""

# Optional: app/server port when you are not using the standard local scripts.
# Leave this unset for `bun run dev:full`; that script already runs Next on 3000
# and the socket server reads PORT before SOCKET_PORT.
# PORT="3000"

# Optional: tell the app it is running inside a Docker image build.
DOCKER_BUILD="false"

# Optional: landing-page preview/dev helper used by getBaseUrl().
# NEXT_PUBLIC_IS_PREVIEW_DEVELOPMENT="false"
